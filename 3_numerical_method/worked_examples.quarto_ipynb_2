      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def draw_iteration(ax, g, x0, n_iter, xlim, ylim, title):\n",
        "    xs = np.linspace(xlim[0], xlim[1], 400)\n",
        "    ax.plot(xs, xs,    color=\"#888888\", lw=1.2, label=\"$y = x$\")\n",
        "    ax.plot(xs, g(xs), color=\"#2563EB\", lw=2,   label=\"$y = g(x)$\")\n",
        "    x = x0\n",
        "    for _ in range(n_iter):\n",
        "        gx = g(x)\n",
        "        ax.plot([x, x],  [x, gx],  color=\"#DC2626\", lw=1, alpha=0.8)\n",
        "        ax.plot([x, gx], [gx, gx], color=\"#DC2626\", lw=1, alpha=0.8)\n",
        "        x = gx\n",
        "    ax.set_xlim(*xlim); ax.set_ylim(*ylim)\n",
        "    ax.axhline(0, color=\"#aaa\", lw=0.6); ax.axvline(0, color=\"#aaa\", lw=0.6)\n",
        "    ax.set_title(title, fontsize=11)\n",
        "    ax.set_xlabel(\"$x$\"); ax.set_ylabel(\"$y$\")\n",
        "    ax.legend(fontsize=9)\n",
        "    ax.grid(True, linestyle=\":\", alpha=0.4)\n",
        "\n",
        "def g1(x): return np.sqrt(5*x + 7)\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(11, 4.5))\n",
        "fig.suptitle(\"i.  $x^2 - 5x - 7 = 0$  →  $g(x) = \\\\sqrt{5x+7}$  [Staircase]\",\n",
        "             fontsize=12, fontweight=\"bold\")\n",
        "draw_iteration(axes[0], g1, x0=6.5, n_iter=7, xlim=(5.8,7.0), ylim=(5.8,7.0),\n",
        "               title=\"from above ($x_0 = 6.5$)\")\n",
        "draw_iteration(axes[1], g1, x0=6.0, n_iter=7, xlim=(5.8,7.0), ylim=(5.8,7.0),\n",
        "               title=\"from below ($x_0 = 6.0$)\")\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "a023c244",
